{
  "name": "storylab",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "npm run test:frontend && npm run test:server && npm run test:rust",
    "test:frontend": "vitest run",
    "test:frontend:watch": "vitest",
    "test:frontend:coverage": "vitest run --coverage",
    "test:server": "npm run test --prefix server",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:e2e": "wdio run test/e2e/wdio.conf.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "fastify": "^5.8.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^1.0.4",
    "autoprefixer": "^10.4.27",
    "jsdom": "^23.0.1",
    "postcss": "^8.5.8",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^1.0.4"
  }
}
